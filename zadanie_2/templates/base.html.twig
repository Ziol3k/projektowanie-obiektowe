<!DOCTYPE html>
<html>
<head>
    <meta charset="UTF-8">
    <title>{% block title %}Symfony App{% endblock %}</title>
    <style>
        body {
            font-family: Arial, sans-serif;
            margin: 40px;
            background: #f5f5f5;
        }

        nav {
            margin-bottom: 20px;
        }

        nav a {
            margin-right: 15px;
            text-decoration: none;
            color: #0d6efd;
            font-weight: bold;
        }

        .container {
            background: white;
            padding: 20px;
            border-radius: 10px;
        }

        table {
            border-collapse: collapse;
            width: 100%;
            margin-top: 20px;
            background: white;
        }

        table, th, td {
            border: 1px solid #ccc;
        }

        th, td {
            padding: 10px;
            text-align: left;
        }

        h1 {
            margin-top: 0;
        }
    </style>
</head>
<body>
    <nav>
        <a href="/products">Products</a>
        <a href="/categories">Categories</a>
        <a href="/orders">Orders</a>
    </nav>

    <div class="container">
        {% block body %}{% endblock %}
    </div>
</body>
</html>