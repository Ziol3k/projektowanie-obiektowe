{% extends 'base.html.twig' %}

{% block title %}Orders{% endblock %}

{% block body %}
    <h1>Orders</h1>

    <table>
        <tr>
            <th>ID</th>
            <th>Customer</th>
            <th>Total amount</th>
            <th>Status</th>
        </tr>
        {% for order in orders %}
            <tr>
                <td>{{ order.id }}</td>
                <td>{{ order.customerName }}</td>
                <td>{{ order.totalAmount }}</td>
                <td>{{ order.status }}</td>
            </tr>
        {% else %}
            <tr>
                <td colspan="4">No orders found.</td>
            </tr>
        {% endfor %}
    </table>
{% endblock %}